@page
@model Yukigroup_WEB.Pages.CustomersModel
@{
    ViewData["Title"] = "顧客一覧";
}

<h1>顧客一覧</h1>

<form method="get">
    <input type="text" name="searchTerm" value="@Request.Query["searchTerm"]" placeholder="名前で検索" />
    <button type="submit">検索</button>
</form>
<table class="table">
    <thead>
        <tr>
            <th>名前</th>
            <th>国名</th>
            <th>参加回数</th>
            <th>学生/社会人</th>
            <th>場所</th>
            <th>日本語レベル</th>
            <th>備考</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var c in Model.CustomerList)
        {
            <tr>
                <td>@c.Name</td>
                <td>@c.Country</td>
                <td>@c.ParticipationCount</td>
                <td>@c.Status</td>
                <td>@c.Place</td>
                <td>@c.JapaneseSkill</td>
                <td>@c.Note</td>
            </tr>
        }
    </tbody>
</table>
